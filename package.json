{
  "name": "serpentia",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; rmSync('.svelte-kit', { recursive: true, force: true })\"",
    "build": "bun run clean && vp build",
    "deploy": "vp build && wrangler deploy",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "check": "bun run clean && wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vp test",
    "test": "vp test run",
    "ready": "vp run check && vp run test && vp run build",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@effect/platform-browser": "^4.0.0-beta.100",
    "bits-ui": "^2.18.1",
    "effect": "^4.0.0-beta.100",
    "howler": "^2.2.4",
    "lucide-svelte": "^1.0.1",
    "pixi.js": "^8.19.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@effect/vitest": "^4.0.0-beta.100",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/howler": "^2.2.13",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite-plus": "0.2.5",
    "wrangler": "^4.97.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "packageManager": "bun@1.3.14"
}
