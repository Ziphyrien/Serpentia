{
  "name": "serpentia",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build && bun --watch server/index.ts",
    "dev:ui": "vp dev",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; for (const path of ['.svelte-kit', 'build']) rmSync(path, { recursive: true, force: true })\"",
    "build": "bun run clean && vp build",
    "start": "bun server/index.ts",
    "preview": "bun run start",
    "backend:secrets": "bun scripts/generate-backend-secrets.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.server.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vp test",
    "test": "vp test run",
    "ready": "vp run check && vp run test && vp run build"
  },
  "dependencies": {
    "bits-ui": "^2.18.1",
    "effect": "^4.0.0-beta.101",
    "howler": "^2.2.4",
    "lucide-svelte": "^1.0.1",
    "msgpackr": "^2.0.4",
    "nipplejs": "^1.0.4",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/howler": "^2.2.13",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite-plus": "0.2.6"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "packageManager": "bun@1.3.14"
}
