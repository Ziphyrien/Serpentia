listening-port=3478
tls-listening-port=5349
fingerprint
use-auth-secret
static-auth-secret=replace-with-the-same-TURN_SHARED_SECRET
realm=voice.example.com
server-name=voice.example.com

# TLS files may be omitted until certificates are installed.
cert=/etc/letsencrypt/live/voice.example.com/fullchain.pem
pkey=/etc/letsencrypt/live/voice.example.com/privkey.pem

no-cli
no-multicast-peers
no-loopback-peers
stale-nonce=600
min-port=49160
max-port=49200

# If the VPS is behind NAT, also set:
# external-ip=PUBLIC_IP/PRIVATE_IP
